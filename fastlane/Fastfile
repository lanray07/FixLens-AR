require "shellwords"
require "fileutils"
require "tmpdir"

default_platform(:ios)

platform :ios do
  desc "Build a cloud-signed IPA with Xcode and upload it to App Store Connect"
  lane :upload_build do
    root_dir = File.expand_path("..", __dir__)
    project_path = ENV.fetch("PROJECT_PATH", "FixLensAR.xcodeproj")
    scheme = ENV.fetch("SCHEME", "FixLensAR")
    configuration = ENV.fetch("CONFIGURATION", "Release")
    bundle_id = ENV.fetch("BUNDLE_ID", "com.fixlens.ar")
    team_id = ENV.fetch("APPLE_TEAM_ID")
    marketing_version = ENV.fetch("MARKETING_VERSION", "1.0")
    build_number = ENV.fetch("BUILD_NUMBER")

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_PRIVATE_KEY").gsub("\\n", "\n"),
      duration: 1200,
      in_house: false
    )

    build_settings = {
      "DEVELOPMENT_TEAM" => team_id,
      "PRODUCT_BUNDLE_IDENTIFIER" => bundle_id,
      "MARKETING_VERSION" => marketing_version,
      "CURRENT_PROJECT_VERSION" => build_number,
      "CODE_SIGN_STYLE" => "Automatic"
    }.map { |key, value| "#{key}=#{Shellwords.escape(value)}" }.join(" ")

    asc_key_dir = Dir.mktmpdir("fixlens-asc-key")
    begin
      asc_key_path = File.join(asc_key_dir, "AuthKey_#{ENV.fetch("ASC_KEY_ID")}.p8")
      File.write(asc_key_path, ENV.fetch("ASC_PRIVATE_KEY").gsub("\\n", "\n"))

      auth_args = [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{Shellwords.escape(asc_key_path)}",
        "-authenticationKeyID #{Shellwords.escape(ENV.fetch("ASC_KEY_ID"))}",
        "-authenticationKeyIssuerID #{Shellwords.escape(ENV.fetch("ASC_ISSUER_ID"))}"
      ].join(" ")

      build_dir = File.join(root_dir, "build")
      archive_path = File.join(build_dir, "FixLensAR.xcarchive")
      export_path = File.join(build_dir, "export")
      export_options_path = File.join(build_dir, "ExportOptions.plist")

      FileUtils.rm_rf(build_dir)
      FileUtils.mkdir_p(export_path)
      File.write(export_options_path, <<~PLIST)
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
          <key>method</key>
          <string>app-store-connect</string>
          <key>teamID</key>
          <string>#{team_id}</string>
          <key>signingStyle</key>
          <string>automatic</string>
          <key>manageAppVersionAndBuildNumber</key>
          <false/>
          <key>uploadSymbols</key>
          <true/>
        </dict>
        </plist>
      PLIST

      sh(
        "xcodebuild " \
        "-project #{Shellwords.escape(File.expand_path(project_path, root_dir))} " \
        "-scheme #{Shellwords.escape(scheme)} " \
        "-configuration #{Shellwords.escape(configuration)} " \
        "-destination #{Shellwords.escape("generic/platform=iOS")} " \
        "-archivePath #{Shellwords.escape(archive_path)} " \
        "#{auth_args} " \
        "#{build_settings} " \
        "clean archive"
      )

      sh(
        "xcodebuild " \
        "-exportArchive " \
        "-archivePath #{Shellwords.escape(archive_path)} " \
        "-exportPath #{Shellwords.escape(export_path)} " \
        "-exportOptionsPlist #{Shellwords.escape(export_options_path)} " \
        "#{auth_args}"
      )

      ipa_path = Dir[File.join(export_path, "*.ipa")].first
      UI.user_error!("No IPA was exported to #{export_path}") unless ipa_path

      upload_to_testflight(
        api_key: api_key,
        app_identifier: bundle_id,
        ipa: ipa_path,
        skip_waiting_for_build_processing: true
      )
    ensure
      FileUtils.rm_rf(asc_key_dir) if asc_key_dir
    end
  end
end
