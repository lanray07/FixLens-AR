require "shellwords"

default_platform(:ios)

platform :ios do
  desc "Create signing assets, build a signed IPA, and upload it to App Store Connect"
  lane :upload_build do
    project_path = ENV.fetch("PROJECT_PATH", "FixLensAR.xcodeproj")
    scheme = ENV.fetch("SCHEME", "FixLensAR")
    configuration = ENV.fetch("CONFIGURATION", "Release")
    bundle_id = ENV.fetch("BUNDLE_ID", "com.fixlens.ar")
    team_id = ENV.fetch("APPLE_TEAM_ID")
    marketing_version = ENV.fetch("MARKETING_VERSION", "1.0")
    build_number = ENV.fetch("BUILD_NUMBER")
    profile_name = ENV.fetch("PROFILE_NAME", "FixLens AR App Store")

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_PRIVATE_KEY").gsub("\\n", "\n"),
      duration: 1200,
      in_house: false
    )

    setup_ci if ENV["CI"]

    cert(
      api_key: api_key,
      team_id: team_id,
      generate_apple_certs: true
    )

    sigh(
      api_key: api_key,
      app_identifier: bundle_id,
      team_id: team_id,
      provisioning_name: profile_name,
      filename: "FixLensAR_AppStore.mobileprovision",
      force: true
    )

    signing_xcargs = {
      "DEVELOPMENT_TEAM" => team_id,
      "PRODUCT_BUNDLE_IDENTIFIER" => bundle_id,
      "MARKETING_VERSION" => marketing_version,
      "CURRENT_PROJECT_VERSION" => build_number,
      "CODE_SIGN_STYLE" => "Manual",
      "PROVISIONING_PROFILE_SPECIFIER" => profile_name,
      "CODE_SIGN_IDENTITY" => "Apple Distribution"
    }.map { |key, value| "#{key}=#{Shellwords.escape(value)}" }.join(" ")

    ipa_path = build_app(
      project: project_path,
      scheme: scheme,
      configuration: configuration,
      clean: true,
      output_directory: "build",
      output_name: "FixLensAR.ipa",
      export_method: "app-store",
      xcargs: signing_xcargs,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          bundle_id => profile_name
        },
        manageAppVersionAndBuildNumber: false
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: bundle_id,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
